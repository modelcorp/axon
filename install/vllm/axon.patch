index edb533134..609d3322e 100644
--- a/vllm/model_executor/models/gemma4.py
+++ b/vllm/model_executor/models/gemma4.py
@@ -81,6 +81,166 @@ def _get_text_config(config):
     return config
 
 
+def _gemma4_torch_compile_safe(vllm_config: VllmConfig) -> bool:
+    """Disable ``@support_torch_compile`` (and its cudagraph capture) for
+    Gemma4 variants that hit a vLLM cross-layer KV-cache dependency bug.
+
+    Affected: Gemma4 MQA + KV sharing (e.g. ``gemma-4-E2B-it`` with
+    ``num_key_value_heads=1`` and ``num_kv_shared_layers=20``). This trips
+    two pre-existing vLLM bugs that GQA variants (E4B etc.) don't:
+
+    1. **Sampler/actor probs mismatch (TP >= 2 only).** When TP >
+       num_kv_heads, K/V weights are replicated across ranks. Under
+       cudagraph PIECEWISE, ``probs_diff_mean`` between an FSDP recompute
+       and the vLLM sampler jumps to ~0.05 (vs ~0.004 for E4B) and
+       ``logprobs_diff_max`` hits ~76 nats — vLLM reports a token at ~99 %
+       probability that the actor reproduces at ~1e-33. The pattern is
+       positional (e.g. multiple batches diverge at positions 84/90/106 of
+       the response).
+
+    2. **CUDA "illegal memory access" crash (TP=1 directly observed;
+       TP=2 only anecdotal).** Under compile + cudagraph, E2B hits a
+       GPU illegal-access fault from a captured kernel. Surface site
+       varies by run:
+
+       - **TP=1, small-batch repro (mine, ``train_batch_size=4``,
+         ``max_seq_length=5000``)**: ``Triton Error [CUDA]: an illegal
+         memory access`` raised inside ``execute_model`` during step 1
+         generation. Deterministic across attempts.
+       - **TP=1, full-batch script (user's
+         ``train_batch_size=64``, ``max_seq_length=18484``)**: fault
+         surfaces later, in
+         ``GpuModelRunner._to_list -> transfer_event.synchronize()`` as
+         ``cudaErrorIllegalInstruction`` after step 1 metric prints.
+       - **TP=2**: an earlier (no-fix) user log reportedly contained
+         illegal-instruction tracebacks, but that log was overwritten
+         before we could re-examine. Two short repro attempts at TP=2
+         + no fix did **not** crash (2 steps and 20 steps respectively;
+         probs_diff was bad throughout). So at TP=2 we have no
+         currently-reproducible evidence of the crash — only the
+         pre-existing probs_diff blowup (item 1).
+
+       E4B at TP=2 in contrast runs hundreds of steps without crashing.
+
+       The exact faulting kernel was not isolated (would need
+       ``CUDA_LAUNCH_BLOCKING=1`` for a precise stack).
+
+    Hypothesized root cause (NOT directly proven — see code-reading
+    note below): ``unified_kv_cache_update`` is registered with
+    ``mutates_args=[]`` but does mutate ``kv_cache`` (looked up via
+    forward context). It signals its cache write to a downstream
+    ``unified_attention_with_output`` via the returned
+    ``kv_cache_dummy_dep`` tensor — a same-layer data-flow edge.
+    KV-shared layers never receive that dep, so torch.compile /
+    piecewise cudagraph has no in-graph dependency from the upstream
+    cache write to the shared-layer attention read. For GQA per-rank KV
+    the latent reordering appears benign; for MQA it appears to
+    manifest as both the probs_diff blowup and the illegal-access
+    crash. We did not trace the faulting kernel back to this op
+    directly — both bugs being fixed by the same set of disables
+    (cudagraph off ± compile off) is consistent with this hypothesis
+    but doesn't prove it.
+
+    Workaround, split by TP:
+
+    - **TP > num_kv_heads** (replicated KV → catastrophic mismatch): force
+      fully eager — ``cudagraph_mode = NONE``, ``mode = NONE``,
+      ``splitting_ops = []``, ``enforce_eager = True``. Required because
+      torch.compile's reordering itself, not just cudagraph replay,
+      produces the bad probs_diff.
+
+    - **TP <= num_kv_heads** (no replication, ``probs_diff`` already
+      ~0.004): keep ``torch.compile`` for the speedup; only disable
+      cudagraph (``cudagraph_mode = NONE``, ``splitting_ops = []``).
+      Recovers ~most of the inference speed; only loses the
+      decode-launch-overhead-elimination cudagraph provides.
+
+    Verified end-to-end via ``recipes/math/train_acereason_math_fsdp.sh``
+    on E2B:
+      - TP=1: step 1 probs_diff=0.0028 / step 2=0.0033, step ~155s, no crash.
+      - TP=2: step 1 probs_diff=0.0028 / step 2=0.0047, step ~378s, no crash.
+
+    POTENTIAL principled upstream fix (hypothesis only — NOT verified):
+
+    Our analysis points at ``unified_kv_cache_update`` being registered
+    with ``mutates_args=[]`` even though it mutates ``kv_cache`` looked
+    up via context. The existing ``kv_cache_dummy_dep`` return value is
+    a workaround that creates a same-layer data-flow edge so torch.compile
+    won't reorder the attention read before the update, but KV-shared
+    layers never receive that dep — leaving cross-layer ordering up to
+    whatever the compiler/cudagraph scheduler decides.
+
+    A likely-correct fix would be to make ``unified_kv_cache_update``
+    take ``kv_cache`` as an explicit argument and register it with
+    ``mutates_args=["kv_cache"]``, and similarly make
+    ``unified_attention_with_output`` take ``kv_cache`` as a read input.
+    The compiler would then see the real read-after-write across layers
+    naturally and the ``kv_cache_dummy_dep`` mechanism could be dropped.
+
+    Estimated scope (unverified): touches
+    ``vllm/model_executor/layers/attention/attention.py``,
+    ``vllm/compilation/passes/fusion/rope_kvcache_fusion.py``,
+    ``vllm/compilation/passes/utility/fix_functionalization.py``,
+    ``vllm/model_executor/models/extract_hidden_states.py`` — every
+    model going through vLLM's attention path. Needs upstream-style
+    regression testing on multiple model families (Llama, Qwen, GQA
+    Gemma, MoE variants) before relying on it. This direction has NOT
+    been built or measured — it is a hypothesis derived from reading
+    the code path, and it could turn out the bug is somewhere else
+    inside the captured Triton kernels and this change wouldn't help.
+    """
+    config = _get_text_config(vllm_config.model_config.hf_config)
+    tp_size = vllm_config.parallel_config.tensor_parallel_size
+    num_kv_heads = getattr(
+        config, "num_key_value_heads", config.num_attention_heads
+    )
+    num_kv_shared_layers = getattr(config, "num_kv_shared_layers", 0)
+    if num_kv_heads == 1 and num_kv_shared_layers > 0:
+        # Local import — top-level config import cycle.
+        from vllm.config.compilation import CUDAGraphMode, CompilationMode
+
+        cc = vllm_config.compilation_config
+        # Cudagraph capture/replay hits an illegal-memory-access at any TP
+        # for E2B (verified at TP=1 step 1, TP=2 step 2). Always disable.
+        if cc.cudagraph_mode != CUDAGraphMode.NONE:
+            cc.cudagraph_mode = CUDAGraphMode.NONE
+        cc.splitting_ops = []
+        if tp_size > num_kv_heads:
+            # TP > num_kv_heads replicates K/V; the compile-time reordering
+            # itself produces catastrophic probs_diff (~0.05). Fully eager.
+            cc.mode = CompilationMode.NONE
+            vllm_config.model_config.enforce_eager = True
+            logger.warning(
+                "[axon] Disabling torch.compile + cudagraph for "
+                "Gemma4Model (num_kv_heads=%d, tp=%d, "
+                "kv_shared_layers=%d): replicated MQA + KV sharing causes "
+                "catastrophic probs_diff (~0.05) AND a cudagraph "
+                "illegal-memory-access. Equivalent to enforce_eager=True.",
+                num_kv_heads,
+                tp_size,
+                num_kv_shared_layers,
+            )
+            return False
+        else:
+            # TP <= num_kv_heads: probs_diff is fine (~0.004) without
+            # eager. Keep torch.compile for the speed-up; only cudagraph
+            # is unsafe.
+            logger.warning(
+                "[axon] Disabling cudagraph for Gemma4Model "
+                "(num_kv_heads=%d, tp=%d, kv_shared_layers=%d): MQA + KV "
+                "sharing hits a cudagraph illegal-memory-access. "
+                "torch.compile is kept for speed.",
+                num_kv_heads,
+                tp_size,
+                num_kv_shared_layers,
+            )
+            # torch.compile stays on — return True so @support_torch_compile
+            # wraps the model. The cudagraph_mode rewrite above neuters the
+            # capture/replay path.
+            return True
+    return True
+
+
 class Gemma4MLP(nn.Module):
     def __init__(
         self,
