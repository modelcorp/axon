+# [axon] Decode image_data from completion request (base64 → PIL Image).
+def _decode_image_data(image_data: list[dict]) -> list[Any]:
+    import base64
+    from io import BytesIO
+
+    from PIL import Image
+    images = []
+    for item in image_data:
+        if isinstance(item, dict) and item.get("type") == "image_base64":
+            raw = base64.b64decode(item["data"])
+            img = Image.open(BytesIO(raw)).convert("RGB")
+            images.append(img)
+        else:
+            raise TypeError(f"Unsupported image_data item: {type(item)}")
+    return images
+
+
 _T = TypeVar("_T", bound=TokenizerLike, default=TokenizerLike)
 
 
