+# FlexAttention mask type keys
+# Registration key (without seq_len, used during __init__)
+FLEX_ATTN_MASK_REG_T = tuple[str, int | None]
+# Full mask key (with seq_len, used for caching actual masks)
+FLEX_ATTN_MASK_T = tuple[str, int | None, int]
+
+def get_kernel_options(query, block_m, block_n,
+                       use_direct_build: bool) -> dict[str, Union[int, bool]]:
+    kernel_options: dict[str, Union[int, bool]] = {
+        "FORCE_USE_FLEX_ATTENTION": True,
+    }
+    kernel_options["BLOCK_M"] = 16
+    kernel_options["BLOCK_N"] = 16
+    kernel_options["IS_DIVISIBLE"] = False
+    return kernel_options
+    if use_direct_build:
+        kernel_options["BLOCK_M"] = block_m
+        kernel_options["BLOCK_N"] = block_n
+        return kernel_options
+    else:
+        kernel_options["BLOCK_M"] = 64
+        kernel_options["BLOCK_N"] = 64
+        if query.dtype == torch.float32:
+            kernel_options["BLOCK_M"] = 32
+            kernel_options["BLOCK_N"] = 32
+        # if current_platform.is_cuda():
+        if torch.cuda.is_available():
+            device_props = torch.cuda.get_device_properties()
+            max_shared_memory = device_props.shared_memory_per_block_optin
+            if max_shared_memory < 144 * 1024:
+                kernel_options["BLOCK_M"] = kernel_options["BLOCK_M"] // 2
+                kernel_options["BLOCK_N"] = kernel_options["BLOCK_N"] // 2
+
+    return kernel_options
+
+
+class FlexAttentionBackend(torch.nn.Module):
+    """FlexAttention backend using torch.nn.attention.flex_attention.
+
+    This backend implements flexible attention patterns using PyTorch's native
+    flex_attention API, which allows for custom masking patterns through mask
+    modification functions.
+
+    Args:
+        softmax_scale (float): Scaling factor for attention scores.
+        attention_type (str): Type of attention ("self" or "cross").
+        attn_mask_type (str): The type of attention mask. Currently supports
+            "causal" and "block_causal". "causal" means the lower triangle of the
+            attention matrix is masked. "block_causal" means the attention matrix
+            is divided into blocks where block boundary is defined by EOS token,
+            and the lower triangle of each block is masked.
+        fixed_block_size (int | None): The block size to be used to perform attention.
+            If specified, each sequence will be further divided to blocks, where each
+            block has the maximum size of ``fixed_block_size``. A query will only attend
+            to the keys within the same block.
+        attention_dropout (float): Dropout probability.
+        attention_dropout_ctx (Callable): Context manager for dropout.
+        layer_number (Optional[int]): Layer number identifier.
+    """
+
+    # Class variables for compiled functions and caching
+    flex_attn: ClassVar[Callable] = None
+    compiled_create_block_mask: ClassVar[Callable] = None
+    used_attn_mask_types: ClassVar[set[FLEX_ATTN_MASK_REG_T]] = set()
+    block_masks: ClassVar[dict[FLEX_ATTN_MASK_T, BlockMask]] = {}
+    _initialized: ClassVar[bool] = False
+
+    def __init__(
+        self,
+        softmax_scale: float,
+        attention_type: str = "self",
+        attn_mask_type: str = "causal",
+        fixed_block_size: int | None = None,
+        attention_dropout: float = 0.0,
+        attention_dropout_ctx: Optional[Callable] = nullcontext,
+        layer_number: Optional[int] = None,
+    ) -> None:
+        super().__init__()
+
+        if not flex_attention_available:
+            raise RuntimeError(
+                "FlexAttention backend requires PyTorch with flex_attention support. "
+                "Please upgrade to a version that includes torch.nn.attention.flex_attention."
+            )
+
+        # Support various causal mask types
+        # padding_causal = causal with padding handling
+        # causal_bottom_right = causal aligned to bottom right
+        supported_mask_types = [
+            "causal",
+            "block_causal", 
+            "padding_causal",
+            "causal_bottom_right",
+            "padding_causal_bottom_right"
+        ]
+        if attn_mask_type not in supported_mask_types:
+            raise ValueError(
+                f"FlexAttention backend only supports {supported_mask_types}, "
+                f"got {attn_mask_type}."
+            )
+
+        self.softmax_scale = softmax_scale
+        self.attention_type = attention_type
+        self.attn_mask_type = attn_mask_type
+        self.fixed_block_size = fixed_block_size
+        self.attention_dropout = attention_dropout
+        self.attention_dropout_ctx = attention_dropout_ctx
+        self.layer_number = 1 if layer_number is None else layer_number
+
+        # Initialize class-level compiled functions once
+        if not FlexAttentionBackend._initialized:
+            FlexAttentionBackend.flex_attn = torch.compile(
+                flex_attention, mode="max-autotune-no-cudagraphs"
+            )
+            FlexAttentionBackend.compiled_create_block_mask = torch.compile(create_block_mask)
+            FlexAttentionBackend._initialized = True
+
+        # Register this mask type
+        FlexAttentionBackend.used_attn_mask_types.add(self.mask_key)
+
+        self.logger = logging.getLogger("FlexAttention")
+        if attn_log._is_logging_setup is False:
+            attn_log.setup_logging()
+        self.logger.setLevel(attn_log._log_level)
+        if not self.logger.hasHandlers():
+            self.logger.addHandler(attn_log._stream_handler)
+
+    @property
+    def mask_key(self) -> FLEX_ATTN_MASK_REG_T:
+        """Generate a registration key for this mask configuration (without seq_len)."""
+        return (self.attn_mask_type, self.fixed_block_size)
+
+    @staticmethod
+    def _get_causal_mask_mod() -> _mask_mod_signature:
+        """Create a causal mask modification function."""
+        def causal_mask(
+            b: torch.Tensor, h: torch.Tensor, q_idx: torch.Tensor, kv_idx: torch.Tensor
+        ):
+            return q_idx >= kv_idx
+
+        return causal_mask
+
+    @staticmethod
+    def _get_block_causal_mask_mod(
+        batch: torch.Tensor, eos_id: int
+    ) -> _mask_mod_signature:
+        """Create a block causal mask modification function.
+        
+        Args:
+            batch: Tensor of shape [b, s, h, d] or [b, s]
+            eos_id: The token ID that marks end of sequence
+        """
+        # Handle different input shapes
+        if batch.ndim == 4:
+            # [b, s, h, d] - take first element across h and d dimensions
+            batch_tokens = batch[:, :, 0, 0]
+        elif batch.ndim == 2:
+            # [b, s]
+            batch_tokens = batch
+        else:
+            raise ValueError(f"Unexpected batch shape: {batch.shape}")
+        
+        mask = batch_tokens == eos_id
+        mask[:, -1] = True
+        acc_mask = torch.cumsum(torch.where(mask, 1, 0), dim=1)
+        seq_idx = torch.zeros_like(acc_mask, dtype=torch.int32)
+        seq_idx[:, 1:] = acc_mask[:, :-1]
+
+        def block_causal_mask(
+            b: torch.Tensor, h: torch.Tensor, q_idx: torch.Tensor, kv_idx: torch.Tensor
+        ):
+            return (seq_idx[b, q_idx] == seq_idx[b, kv_idx]) & (q_idx >= kv_idx)
+
+        return block_causal_mask
+
+    @staticmethod
+    def _fixed_block_mask_mod(
+        mask_mod: _mask_mod_signature, fixed_block_size: int
+    ) -> _mask_mod_signature:
+        """Wrap a mask mod to apply fixed block partitioning.
+        
+        This restricts attention to within fixed-size blocks while still applying
+        the underlying mask (e.g., causal) using global token positions.
+        
+        Args:
+            mask_mod: The base mask modification function
+            fixed_block_size: The number of tokens in each block
+        """
+        def blocked_mask_mod(
+            b: torch.Tensor, h: torch.Tensor, q_idx: torch.Tensor, kv_idx: torch.Tensor
+        ):
+            # Get the block index of the query and key
+            q_block = q_idx // fixed_block_size
+            kv_block = kv_idx // fixed_block_size
+            # Only allow attention within the same block
+            same_block = q_block == kv_block
+            # Apply the original mask mod with GLOBAL indices (not local)
+            # This ensures causal masking respects global token positions
+            inner_mask = mask_mod(b, h, q_idx, kv_idx)
+            return same_block & inner_mask
+
+        blocked_mask_mod.__name__ = (
+            f"blocked_mask_mod_{mask_mod.__name__}_fixed_block_size_{fixed_block_size}"
+        )
+        return blocked_mask_mod
+
+    @staticmethod
+    @torch.no_grad()
+    def init_attention_mask(
+        batch: torch.Tensor, 
+        eos_id: int | None,
+        cp_mesh: torch.distributed.device_mesh.DeviceMesh | None = None,
+    ) -> None:
+        """Initialize attention masks for all registered mask types.
+        
+        Args:
+            batch: Input batch tensor, shape can be [b, s, h, d] or [b, s]
+            eos_id: End-of-sequence token ID (required for block_causal)
+            cp_mesh: Context parallel device mesh (not yet fully supported)
+        """
+        # Handle CP mesh if provided
+        if cp_mesh is not None:
+            try:
+                from torch.distributed.tensor.experimental._attention import create_cp_block_mask
+                FlexAttentionBackend.compiled_create_block_mask = functools.partial(
+                    create_cp_block_mask, device_mesh=cp_mesh
+                )
+            except ImportError:
+                warnings.warn(
+                    "Context parallelism with FlexAttention requires torch.distributed.tensor "
+                    "with create_cp_block_mask support. Falling back to standard block mask."
+                )
+
+        for reg_key in FlexAttentionBackend.used_attn_mask_types:
+            attn_mask_type, fixed_block_size = reg_key
+            
+            # Determine sequence length from batch
+            if batch.ndim == 4:
+                seq_len = batch.shape[1]  # [b, s, h, d]
+            elif batch.ndim == 2:
+                seq_len = batch.shape[1]  # [b, s]
+            else:
+                raise ValueError(f"Unexpected batch shape: {batch.shape}")
+            
+            # Create new mask key with actual sequence length
+            actual_mask_key = (attn_mask_type, fixed_block_size, seq_len)
+            
+            # Skip if already initialized for this exact configuration
+            if FlexAttentionBackend.block_masks.get(actual_mask_key, None) is not None:
+                continue
+            
+            # Determine batch dimension and create mask mod
+            if attn_mask_type == "causal":
+                # Causal mask is batch-agnostic
+                batch_dimension = 1
+                mask_mod = FlexAttentionBackend._get_causal_mask_mod()
+            elif attn_mask_type == "block_causal":
+                if eos_id is None:
+                    raise RuntimeError(
+                        "eos_id must be provided for block_causal mask."
+                    )
+                # Extract batch dimension
+                batch_dimension = batch.shape[0]
+                mask_mod = FlexAttentionBackend._get_block_causal_mask_mod(batch, eos_id)
+            else:
+                raise RuntimeError(f"Unsupported mask type: {attn_mask_type}")
+
+            # NOTE: fixed_block_size is used for compilation hints, not to change mask pattern
+            # If you want block-sparse attention, use "block_causal" mask type instead
+
+            # Create block mask
+            block_mask = FlexAttentionBackend.compiled_create_block_mask(
+                mask_mod, batch_dimension, None, seq_len, seq_len, BLOCK_SIZE=(self.fixed_block_size, self.fixed_block_size),
+            )
+            FlexAttentionBackend.block_masks[actual_mask_key] = block_mask
+
+    def forward(
+        self,
+        query_layer: torch.Tensor,
+        key_layer: torch.Tensor,
+        value_layer: torch.Tensor,
+        qkv_layout: str = "sbh3d",
+        attn_mask_type: str = None,
+        cu_seqlens_q: torch.Tensor = None,
+        cu_seqlens_kv: torch.Tensor = None,
+        max_seqlen_q: int = None,
+        max_seqlen_kv: int = None,
+        **kwargs
+    ) -> torch.Tensor:
+        """FlexAttention forward pass.
+        
+        Args:
+            query_layer: Query tensor
+            key_layer: Key tensor
+            value_layer: Value tensor
+            qkv_layout: Layout format (e.g., "sbhd", "bshd", "thd")
+            attn_mask_type: Override for attention mask type
+            cu_seqlens_q: Cumulative sequence lengths for query (for THD format)
+            cu_seqlens_kv: Cumulative sequence lengths for key/value (for THD format)
+            max_seqlen_q: Maximum sequence length for query (for THD format)
+            max_seqlen_kv: Maximum sequence length for key/value (for THD format)
+            **kwargs: Additional arguments (ignored for compatibility)
+        
+        Returns:
+            Attention output tensor
+        """
+        import transformer_engine_torch as tex
+        
+        # Use mask type from initialization if not provided
+        if attn_mask_type is None:
+            attn_mask_type = self.attn_mask_type
+        
+        # For padding_causal variants, treat as causal for mask purposes
+        mask_type_for_key = attn_mask_type
+        if "padding_causal" in attn_mask_type:
+            mask_type_for_key = "causal"
+        elif attn_mask_type == "causal_bottom_right":
+            mask_type_for_key = "causal"
+        
+        # Determine actual sequence length from input
+        if qkv_layout in ["thd", "thd_thd_thd"]:
+            # For THD, seq_len is from max_seqlen parameter
+            seq_len = max_seqlen_q if max_seqlen_q is not None else 2048
+            batch_dimension = len(cu_seqlens_q) - 1 if cu_seqlens_q is not None else 1
+        elif qkv_layout in ["sbhd", "sbh3d", "sbhd_sbhd_sbhd"]:
+            # For SBHD: [seq, batch, heads, dim]
+            seq_len = query_layer.shape[0] if query_layer.ndim == 4 else 2048
+            batch_dimension = query_layer.shape[1] if query_layer.ndim == 4 else 1
+        else:
+            # For BSHD: [batch, seq, heads, dim]
+            seq_len = query_layer.shape[1] if query_layer.ndim == 4 else 2048
+            batch_dimension = query_layer.shape[0] if query_layer.ndim == 4 else 1
+        
+        # Create full mask key with sequence length
+        mask_key = (mask_type_for_key, self.fixed_block_size, seq_len)
+        
+        # Auto-initialize mask if not already initialized for this seq_len
+        if mask_key not in FlexAttentionBackend.block_masks:
+            # Create mask mod function
+            if mask_type_for_key == "causal":
+                mask_mod = FlexAttentionBackend._get_causal_mask_mod()
+            elif mask_type_for_key == "block_causal":
+                # For block_causal, we can't auto-initialize without batch tokens and eos_id
+                raise RuntimeError(
+                    f"FlexAttention mask for block_causal requires initialization with batch tokens and eos_id. "
+                    "Please call attention.init_flex_attention_mask(batch=input_tokens, eos_id=eos_token_id) "
+                    "before the forward pass."
+                )
+            else:
+                raise RuntimeError(f"Unsupported mask type for auto-initialization: {mask_type_for_key}")
+            
+            # NOTE: fixed_block_size is used for compilation hints, not to change mask pattern
+            # If you want block-sparse attention, use "block_causal" mask type instead
+            
+            # Create and cache the block mask
+            # For causal masks, we only need batch_dimension=1 (mask is same for all batches)
+            block_mask = FlexAttentionBackend.compiled_create_block_mask(
+                mask_mod, 
+                1 if mask_type_for_key == "causal" else batch_dimension,
+                None, 
+                seq_len, 
+                seq_len,
+                BLOCK_SIZE=(self.fixed_block_size, self.fixed_block_size),
+            )
+            FlexAttentionBackend.block_masks[mask_key] = block_mask
+            
+            self.logger.debug(
+                "Auto-initialized FlexAttention mask: type=%s, fixed_block_size=%s, seq_len=%d",
+                mask_type_for_key, self.fixed_block_size, seq_len
+            )
+        
+        # Get the block mask
+        block_mask = FlexAttentionBackend.block_masks[mask_key]
+        
+        # Store original format for output conversion
+        original_layout = qkv_layout
+        total_tokens_q = None
+        batch_size = None
+        
+        # Handle different QKV layouts
+        # FlexAttention expects BHSD format (batch, heads, seq, dim)
+        if qkv_layout in ["thd", "thd_thd_thd"]:
+            # THD format: [total_tokens, num_heads, head_dim]
+            # Need to convert to BSHD first
+            if cu_seqlens_q is None or max_seqlen_q is None:
+                raise ValueError("cu_seqlens_q and max_seqlen_q required for THD format")
+            
+            total_tokens_q = query_layer.shape[0]
+            batch_size = len(cu_seqlens_q) - 1
+            
+            # Convert THD to BSHD using TE utility
+            query_layer = tex.convert_thd_to_bshd(
+                query_layer,
+                cu_seqlens_q,
+                batch_size,
+                max_seqlen_q,
+            )
+            key_layer = tex.convert_thd_to_bshd(
+                key_layer,
+                cu_seqlens_kv,
+                batch_size,
+                max_seqlen_kv,
+            )
+            value_layer = tex.convert_thd_to_bshd(
+                value_layer,
+                cu_seqlens_kv,
+                batch_size,
+                max_seqlen_kv,
+            )
+            # Now in BSHD format
+        elif qkv_layout in ["sbhd", "sbh3d", "sbhd_sbhd_sbhd"]:
+            # [s, b, h, d] -> [b, s, h, d]
+            query_layer = query_layer.transpose(0, 1)
+            key_layer = key_layer.transpose(0, 1)
+            value_layer = value_layer.transpose(0, 1)
+        elif qkv_layout in ["bshd", "bsh3d", "bshd_bshd_bshd"]:
+            # Already in [b, s, h, d] format
+            pass
+        else:
+            raise ValueError(f"Unsupported qkv_layout: {qkv_layout}")
+        
+        # Ensure contiguous memory layout
+        query_layer = query_layer.contiguous()
+        key_layer = key_layer.contiguous()
+        value_layer = value_layer.contiguous()
+        
+        # FlexAttention expects [batch, seq, heads, dim] -> need to transpose
+        # Current: [b, s, h, d]
+        # Required: [b, h, s, d]
+        query_layer = query_layer.transpose(1, 2)
+        key_layer = key_layer.transpose(1, 2)
+        value_layer = value_layer.transpose(1, 2)
+        
+        # Detect GQA (Grouped Query Attention)
+        # GQA: multiple query heads share the same key/value heads
+        num_q_heads = query_layer.shape[1]  # [b, h_q, s, d]
+        num_kv_heads = key_layer.shape[1]   # [b, h_kv, s, d]
+        enable_gqa = num_q_heads != num_kv_heads
+        
+        if enable_gqa:
+            self.logger.debug(
+                "GQA detected: %d query heads, %d key/value heads",
+                num_q_heads, num_kv_heads
+            )
+        
+        # Apply flex attention
+        with self.attention_dropout_ctx():
+            kernel_options = get_kernel_options(query_layer, self.fixed_block_size, self.fixed_block_size,
+                True)
+            output = FlexAttentionBackend.flex_attn(
+                query_layer, 
+                key_layer, 
+                value_layer, 
+                block_mask=block_mask, 
+                scale=self.softmax_scale,
+                enable_gqa=enable_gqa,
+                kernel_options=kernel_options
+            )
+        
+        # Convert back to original layout: [b, h, s, d] -> [b, s, h, d]
+        output = output.transpose(1, 2)
+        
+        # Convert back to original input layout if needed
+        if original_layout in ["thd", "thd_thd_thd"]:
+            # Convert back from BSHD to THD
+            output = tex.convert_bshd_to_thd(
+                output,
+                cu_seqlens_q,
+                total_tokens_q,
+            )
+            # Output is now [total_tokens, num_heads, head_dim]
+            # Flatten to [total_tokens, num_heads * head_dim]
+            output = output.contiguous()
+            return output.view(output.shape[0], -1)
+        elif original_layout in ["sbhd", "sbh3d", "sbhd_sbhd_sbhd"]:
+            # [b, s, h, d] -> [s, b, h, d]
+            output = output.transpose(0, 1)
+        
+        # Flatten to [..., h*d]
+        output = output.contiguous()
+        return output.view(*output.shape[:-2], -1)
